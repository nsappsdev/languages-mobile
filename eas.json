{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview-ios": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://lezoo.app/api"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://lezoo.app/api",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      },
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "distribution": "store"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "internal"
      },
      "ios": {
        "appleId": "nsapps.dev@gmail.com",
        "ascAppId": "PASTE_APP_STORE_CONNECT_APP_ID_HERE",
        "appleTeamId": "PASTE_APPLE_TEAM_ID_HERE"
      }
    }
  }
}
